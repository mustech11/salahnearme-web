import { createClient } from "@supabase/supabase-js";
import MosquesClient from "./MosquesClient";
import FeaturedBusinesses from "@/components/FeaturedBusinesses";

export const revalidate = 300; // cache 5 minutes for speed

const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!
);

export default async function Page() {
  const { data, error } = await supabase
    .from("mosques")
    .select("id,name,slug,postcode,area,verified_status,latitude,longitude")
    .eq("city", "Manchester")
    .order("name", { ascending: true });

  if (error) {
    return <pre className="text-white/80">{error.message}</pre>;
  }

  return (
  <div>
    <MosquesClient initialMosques={data ?? []} />
    <FeaturedBusinesses city="Manchester" />
  </div>
);
}

